{
  "name": "aristotle-cli",
  "version": "1.0.0",
  "description": "A RAG-powered CLI agent that embodies Aristotle, grounded in 18 of his complete works",
  "type": "module",
  "bin": {
    "aristotle": "./dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "start": "node dist/index.js"
  },
  "keywords": [
    "aristotle",
    "philosophy",
    "cli",
    "rag",
    "nicomachean-ethics",
    "ancient-philosophy"
  ],
  "author": "danit",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@huggingface/transformers": "^3.3.3",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.7",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
